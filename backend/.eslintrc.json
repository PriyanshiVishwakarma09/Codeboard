{
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^(next|req|res|err|_)" }],
    "no-console": "off",
    "no-empty": ["error", { "allowEmptyCatch": true }]
  }
}
